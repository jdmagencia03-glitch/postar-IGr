# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Meta / Facebook App (Configurações → Básico)
META_APP_ID=
META_APP_SECRET=

# Instagram App (Instagram → Login do Instagram) — USE ESTES
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=

# URL pública do app (OAuth e links legais)
NEXT_PUBLIC_APP_URL=https://seu-app.vercel.app

# Segurança (OBRIGATÓRIO em produção — use valores aleatórios longos e diferentes)
CRON_SECRET=
SESSION_SECRET=
TOKEN_ENCRYPTION_KEY=

# Opcional
OPENAI_API_KEY=

# TikTok for Developers (Login Kit + Content Posting API)
# Portal: https://developers.tiktok.com
# Redirect URI: {NEXT_PUBLIC_APP_URL}/api/auth/tiktok/callback
# Scopes: user.info.basic, user.info.profile, video.upload, video.publish
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
