# Supabase (banco de dados + auth)
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Rate limiting (requisições por minuto por IP)
RATE_LIMIT_API_PER_MIN=120
RATE_LIMIT_UPLOAD_PER_MIN=600
RATE_LIMIT_AUTH_PER_MIN=24
RATE_LIMIT_AI_PER_MIN=30
RATE_LIMIT_ADMIN_PER_MIN=90
RATE_LIMIT_WEBHOOK_PER_MIN=300

# Bunny.net Stream (recomendado — TUS resumível + CDN)
MEDIA_STORAGE_PROVIDER=bunny
BUNNY_MEDIA_BACKEND=stream
BUNNY_STREAM_LIBRARY_ID=689933
BUNNY_STREAM_API_KEY=
BUNNY_STREAM_CDN_HOSTNAME=vz-3b70f876-76d.b-cdn.net

# Bunny.net Storage (alternativa — upload PUT direto)
# BUNNY_MEDIA_BACKEND=storage
# BUNNY_STORAGE_ZONE=postarigr-media
# BUNNY_STORAGE_ACCESS_KEY=
# BUNNY_STORAGE_REGION=br
# BUNNY_CDN_HOSTNAME=postarigr.b-cdn.net

# Upload
SUPABASE_MAX_UPLOAD_MB=500
MAX_VIDEOS_PER_BATCH=600
MEDIA_CLEANUP_DELAY_HOURS=2

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
META_APP_ID=
META_APP_SECRET=
META_REDIRECT_URI=http://localhost:3000/api/auth/meta/callback
CRON_SECRET=

# Opcional
OPENAI_API_KEY=
