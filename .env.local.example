# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Meta / Facebook App (Configurações → Básico)
META_APP_ID=
META_APP_SECRET=

# Instagram App (Instagram → Login do Instagram) — USE ESTES
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=

# Após deploy na Vercel, use sua URL pública:
META_REDIRECT_URI=https://seu-app.vercel.app/api/auth/meta/callback
NEXT_PUBLIC_APP_URL=https://seu-app.vercel.app

# Segurança do cron (cron-job.org)
CRON_SECRET=

# Sessão do app (use um valor aleatório; se vazio, usa CRON_SECRET)
SESSION_SECRET=

# Opcional
OPENAI_API_KEY=
