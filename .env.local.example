# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Supabase Pro — ative limites e performance maiores de upload/storage
SUPABASE_PLAN=pro
NEXT_PUBLIC_SUPABASE_PLAN=pro
# Tamanho máximo por vídeo em MB (Pro: até 1024 = 1GB; bucket pode ir até 500GB)
SUPABASE_MAX_UPLOAD_MB=1024
NEXT_PUBLIC_SUPABASE_MAX_UPLOAD_MB=1024
# Vídeos por lote (opcional; padrão Pro = 10000)
# MAX_VIDEOS_PER_BATCH=10000
# Horas após publicar para apagar vídeo do storage (padrão: 2)
# MEDIA_CLEANUP_DELAY_HOURS=2

# Upload paralelo por modo (opcional; padrão: Econômico 2 · Normal 4 · Turbo 6)
# Navegadores limitam ~6 conexões HTTP por domínio — valores acima de 6 são reduzidos automaticamente.
# UPLOAD_CONCURRENCY_ECONOMY=2
# UPLOAD_CONCURRENCY_NORMAL=4
# UPLOAD_CONCURRENCY_TURBO=6

# Meta / Facebook App (Configurações → Básico)
META_APP_ID=
META_APP_SECRET=

# Instagram App (Instagram → Login do Instagram) — USE ESTES
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=

# URL pública do app (OAuth e links legais)
NEXT_PUBLIC_APP_URL=https://seu-app.vercel.app

# Segurança (OBRIGATÓRIO em produção — use valores aleatórios longos e diferentes)
CRON_SECRET=
SESSION_SECRET=
TOKEN_ENCRYPTION_KEY=

# Webhook Meta (Instagram comments → DM automation)
# Configure o mesmo valor em Meta Developer → Webhooks → Verify Token
META_WEBHOOK_VERIFY_TOKEN=

# Opcional
OPENAI_API_KEY=

# TikTok for Developers (Login Kit + Content Posting API)
# Portal: https://developers.tiktok.com
# Redirect URI: {NEXT_PUBLIC_APP_URL}/api/auth/tiktok/callback
# Scopes: user.info.basic, user.info.profile, video.upload, video.publish
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
