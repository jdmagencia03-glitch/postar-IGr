# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Supabase Pro — ative limites e performance maiores de upload/storage
SUPABASE_PLAN=pro
NEXT_PUBLIC_SUPABASE_PLAN=pro
# Tamanho máximo por vídeo em MB (Pro: até 1024 = 1GB; bucket pode ir até 500GB)
SUPABASE_MAX_UPLOAD_MB=1024
NEXT_PUBLIC_SUPABASE_MAX_UPLOAD_MB=1024
# Vídeos por lote (opcional; padrão Pro = 10000)
# MAX_VIDEOS_PER_BATCH=10000
# Horas após publicar para apagar vídeo do storage (padrão: 2)
# MEDIA_CLEANUP_DELAY_HOURS=2

# Upload paralelo por modo (opcional; padrão: Econômico 2 · Normal 4 · Turbo 6)
# Navegadores limitam ~6 conexões HTTP por domínio — valores acima de 6 são reduzidos automaticamente.
# UPLOAD_CONCURRENCY_ECONOMY=2
# UPLOAD_CONCURRENCY_NORMAL=4
# UPLOAD_CONCURRENCY_TURBO=6

# Timeouts de upload (ms) — aumente em conexões muito lentas
# UPLOAD_STALL_TIMEOUT_MS=300000
# UPLOAD_BATCH_STALL_TIMEOUT_MS=420000

# Meta / Facebook App (Configurações → Básico)
META_APP_ID=
META_APP_SECRET=

# Instagram App (Instagram → Login do Instagram) — USE ESTES
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=

# URL pública do app (OAuth e links legais)
NEXT_PUBLIC_APP_URL=https://seu-app.vercel.app

# Segurança (OBRIGATÓRIO em produção — use valores aleatórios longos e diferentes)
# Rotacione CRON_SECRET se exposto. Gere com: openssl rand -hex 32
CRON_SECRET=
SESSION_SECRET=
TOKEN_ENCRYPTION_KEY=

# Fila profissional de agendamento (Inngest — recomendado em produção)
# Crie em https://www.inngest.com e conecte ao app Vercel
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# Migração automática de SQL (opcional — /api/cron/migrate-db)
# Senha do banco em Supabase → Project Settings → Database → Connection string (URI)
# DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?sslmode=require
# Ou configure só a senha (monta a URL automaticamente):
# SUPABASE_DB_PASSWORD=
# SUPABASE_DB_REGION=us-east-1
# Apply atômico de horários: exige DATABASE_URL ou SUPABASE_DB_PASSWORD na Vercel Production
# Alternativa: execute supabase/apply-schedule-moves-atomic.sql no Supabase SQL Editor

# Webhook Meta (Instagram comments → DM automation)
# Configure o mesmo valor em Meta Developer → Webhooks → Verify Token
META_WEBHOOK_VERIFY_TOKEN=

# Opcional
OPENAI_API_KEY=

# Painel Diagnóstico Admin (auditoria operacional — somente leitura)
# Conta hub Instagram com acesso ao painel de todas as contas do owner:
PLATFORM_ADMIN_HUB_IG=deolhonoshape3s
# IDs de owner com acesso admin (separados por vírgula, opcional):
# PLATFORM_ADMIN_OWNER_IDS=
#
# Cron automático do diagnóstico (cron-job.org ou Vercel Cron):
# GET /api/admin/audit/cron?tier=critical  — a cada 5 min
# GET /api/admin/audit/cron?tier=schedule  — a cada 15 min
# Header: Authorization: Bearer {CRON_SECRET}
# Execute supabase/audit-findings.sql no Supabase antes de usar histórico/validação.

# TikTok for Developers (Login Kit + Content Posting API)
# Portal: https://developers.tiktok.com
# Redirect URI (cadastre exatamente no painel TikTok):
#   {NEXT_PUBLIC_APP_URL}/api/auth/tiktok/callback
#   (legado, também suportado: {NEXT_PUBLIC_APP_URL}/api/tiktok/callback)
# Scopes: user.info.basic, user.info.profile, video.upload, video.publish
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
# Método de envio de vídeo para TikTok: file_upload (padrão) ou pull_from_url
# file_upload evita url_ownership_unverified com Supabase Storage
# TIKTOK_UPLOAD_METHOD=file_upload
# TIKTOK_REDIRECT_URI=https://seu-app.vercel.app/api/tiktok/callback
# TIKTOK_SCOPES=user.info.basic,user.info.profile,video.upload,video.publish
# Cron usa PUBLIC_TO_EVERYONE só se true, creator_info incluir a opção E Direct Post auditado
# TIKTOK_PUBLIC_POSTING_ENABLED=false
# TIKTOK_DIRECT_POST_AUDIT_APPROVED=false
# Legado: app auditado no TikTok Developers (informativo nos logs)
# TIKTOK_CLIENT_AUDITED=false
